# App
APP_ENV=development
APP_NAME=Avenue
FRONTEND_URL=http://localhost:3000

# Security
SECRET_KEY=change_me_to_a_very_long_random_secret_string_at_least_64_chars
ENCRYPTION_KEY=change_me_to_a_32_byte_hex_string_for_aes256_encryption_here

# Database
DATABASE_URL=postgresql+asyncpg://avenue_user:avenue_pass@localhost:5432/avenue_db

# Redis (webhook retry queue)
REDIS_URL=redis://localhost:6379

# Nomba
NOMBA_BASE_URL=https://api.nomba.com

# AI Engine
OPENAI_API_KEY=sk-...
AI_CONFIDENCE_THRESHOLD=0.75

# Outbound Webhooks
WEBHOOK_MAX_RETRIES=5

# Email (Resend)
RESEND_API_KEY=re_xxxxxxxxxxxxxx
EMAIL_FROM=hello@avenue.so
